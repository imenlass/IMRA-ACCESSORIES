# ──────────────────────────────────────────────────────────────────
# IMRA Next.js — .gitignore
# Most rules are inherited from the top-level .gitignore. This file
# adds anything specific to running `npm` inside this directory.
# ──────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/
build/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Env files — NEVER commit
.env
.env.local
.env*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Coverage / testing
/coverage
.nyc_output

# Deployment caches
.vercel
.netlify/

# Editors / IDEs
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Misc
*.bak
*.tmp
.cache/
